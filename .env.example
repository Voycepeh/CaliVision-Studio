# Public Supabase configuration for hosted auth + drills persistence.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-public-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional fallback list when JWT role claims are not configured.
EXCHANGE_MODERATOR_USER_IDS=uuid-1,uuid-2

# Backward-compatible fallback for older setups (optional):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
